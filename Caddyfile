# Caddyfile: Vaultec backend, plain HTTP.
#
# TLS is terminated UPSTREAM by Nginx Proxy Manager (public Let's Encrypt cert
# via Cloudflare DNS challenge), which reverse-proxies to this container over
# HTTP. Do NOT add `tls internal` / a :443 block here — double-TLS makes the
# NPM -> Caddy hop fail the handshake (502 at the proxy).
#
# NPM proxy host: scheme http, forward to <this-host-ip>:80, Force SSL on.
:80 {
    # API endpoints -> FastAPI. `handle` blocks are mutually exclusive and
    # evaluated in order, so these take precedence over the SPA fallback below.
    # (A global `try_files ... /index.html` would otherwise rewrite POST /setup
    # to /index.html and the static file_server would answer POST with 405.)
    @api path /api/* /health /unlock /setup
    handle @api {
        reverse_proxy api:8000
    }

    # Everything else: static SPA from /srv/vaultec, with index.html fallback
    # so client-side routing works for deep links.
    handle {
        root * /srv/vaultec
        try_files {path} /index.html
        file_server
    }
}
