# Vaultec Environment Variables

# Database
DATABASE_URL=postgresql://vaultec:vaultec_dev_password@localhost:5432/vaultec
POSTGRES_USER=vaultec
POSTGRES_PASSWORD=vaultec_dev_password
POSTGRES_DB=vaultec

# Vault paths (mount these on a LUKS-encrypted disk in production)
VAULT_BLOB_DIR=/vault/blobs
VAULT_TMP_DIR=/vault/tmp
VAULT_INCOMING_DIR=/vault/incoming

# Application
APP_ENV=dev
SESSION_COOKIE_NAME=vaultec_session

# Optional scanner FTP drop-target (see docs/SCANNER_SETUP.md).
# Only used when started with: docker compose --profile scanner up -d scanner-ftp
SCANNER_FTP_USER=scanner
SCANNER_FTP_PASS=changeme
SCANNER_FTP_PUBLICHOST=192.168.1.50   # set to the Vaultec server's LAN IP

# --- AI features (OCR + embeddings + RAG) ---
# Master switch for the processing worker + AI endpoints.
AI_ENABLED=true
# Provider per capability. Default local (nothing leaves the box). Cloud opt-in.
#   EMBED_PROVIDER: ollama | openai        CHAT_PROVIDER: ollama | anthropic
EMBED_PROVIDER=ollama
CHAT_PROVIDER=ollama
# Vector size the embeddings hold. nomic-embed-text=768, OpenAI 3-small=1536.
EMBED_DIM=768
# Local Ollama (heavy: only starts with `docker compose up ... ollama`; pull the
# models once: `docker exec vaultec-ollama ollama pull nomic-embed-text qwen2.5:3b`)
OLLAMA_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen2.5:3b
# Cloud opt-in — leave blank unless the matching provider is selected above.
# SECURITY: cloud providers receive document text. Set EMBED_DIM=1536 for OpenAI.
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Admin passphrase (TODO: Remove after initial setup)
# ADMIN_PASSPHRASE=your_secure_passphrase_here
